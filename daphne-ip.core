targets:
  default: &default_target
    description: Synthesizable k26c_board_shell PL source manifest
    filesets:
      - rtl_vhdl
      - rtl_verilog
      - daq_vhdl_93
      - daq_vhdl_2008
      - daq_verilog
      - rtl_top
  sim-src:
    <<: *default_target
    description: Source manifest including HDL test benches
    filesets_append:
      - sim_vhdl
      - sim_verilog
  vivado-src:
    <<: *default_target
    description: Source manifest plus Tcl/XCI collateral expected by Vivado
    filesets_append:
      - daq_tcl
