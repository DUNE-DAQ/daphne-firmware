CAPI=2:

name: dune-daq:daphne:daphne-composable-top-validate:0.1.0
description: Public composable DAPHNE top shell for offline validation with a validate-only frontend island
provider:
  name: local

filesets:
  rtl:
    depend:
      - dune-daq:daphne:daphne-package:0.1.0
      - dune-daq:daphne:daphne-subsystem-types:0.1.0
      - dune-daq:daphne:frontend-island-validate-stub:0.1.0
      - dune-daq:daphne:daphne-composable-frontend-shell-selftrigger-off:0.1.0
    files:
      - ../../rtl/isolated/tops/daphne_composable_top.vhd
    file_type: vhdlSource

targets:
  default:
    filesets:
      - rtl
