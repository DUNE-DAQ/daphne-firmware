    depend:
      - dune-daq:daphne:daphne-subsystem-types:0.1.0
    files:
      - rtl/isolated/subsystems/control/trigger_control_adapter.vhd
    file_type: vhdlSource-2008

targets:
  default:
    filesets:
      - rtl
