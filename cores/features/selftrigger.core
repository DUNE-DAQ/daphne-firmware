CAPI=2:

name: dune-daq:daphne:selftrigger:0.1.0
description: Self-trigger feature block with smoke-test and legacy simulation targets
provider:
  name: local

filesets:
  rtl_vhdl:
    depend:
      - dune-daq:daphne:daphne-package:0.1.0
      - dune-daq:daphne:daphne-subsystem-primitives:0.1.0
      - dune-daq:daphne:daphne-subsystem-types:0.1.0
      - dune-daq:daphne:legacy-deimos-readout-bridge:0.1.0
      - dune-daq:daphne:legacy-selftrigger-core-bridge:0.1.0
      - dune-daq:daphne:legacy-selftrigger-datapath:0.1.0
    files:
      - ip_repo/daphne_ip/rtl/selftrig/baseline.vhd
      - ip_repo/daphne_ip/rtl/selftrig/xcorr_import/hpf_pedestal_recovery_filter_trigger.vhd
      - ip_repo/daphne_ip/rtl/selftrig/peak_descriptor_import/Configurable_CFD.vhd
      - ip_repo/daphne_ip/rtl/selftrig/peak_descriptor_import/Peak_Descriptors.vhd
      - ip_repo/daphne_ip/rtl/selftrig/peak_descriptor_import/PeakDetector_SelfTrigger.vhd
      - ip_repo/daphne_ip/rtl/selftrig/peak_descriptor_import/Peak_Descriptor_Calculation.vhd
      - ip_repo/daphne_ip/rtl/selftrig/core.vhd
      - ip_repo/daphne_ip/rtl/selftrig/dual_st20_top.vhd
      - ip_repo/daphne_ip/rtl/selftrig/eia_selftrig/dsp_xc.vhd
      - ip_repo/daphne_ip/rtl/selftrig/eia_selftrig/st_xc.vhd
      - rtl/isolated/subsystems/trigger/legacy_selftrigger_datapath.vhd
      - ip_repo/daphne_ip/rtl/selftrig/selftrig_core.vhd
      - ip_repo/daphne_ip/rtl/selftrig/st20_top.vhd
      - ip_repo/daphne_ip/rtl/selftrig/st40_top.vhd
      - ip_repo/daphne_ip/rtl/selftrig/stc3.vhd
      - ip_repo/daphne_ip/rtl/selftrig/thresholds.vhd
      - ip_repo/daphne_ip/rtl/selftrig/trig.vhd
      - ip_repo/daphne_ip/rtl/selftrig/trig_xc.vhd
    file_type: vhdlSource-2008
  rtl_thresholds:
    depend:
      - dune-daq:daphne:daphne-package:0.1.0
    files:
      - ip_repo/daphne_ip/rtl/selftrig/thresholds.vhd
    file_type: vhdlSource-2008
  rtl_verilog:
    files:
      - ip_repo/daphne_ip/rtl/selftrig/xcorr_import/IIRFilter_afe_integrator_optimized.v
      - ip_repo/daphne_ip/rtl/selftrig/xcorr_import/k_low_pass_filter.v
    file_type: verilogSource
  tb_axi_smoke:
    files:
      - tests/logic/thresholds_axi_smoke_tb.vhd
    file_type: vhdlSource-2008
  tb_legacy_vhdl:
    files:
      - ip_repo/daphne_ip/sim/selftrig/st40_top_testbench.vhd
      - ip_repo/daphne_ip/sim/selftrig/stc3_testbench.vhd
    file_type: vhdlSource-2008
  tb_legacy_data:
    files:
      - ip_repo/daphne_ip/sim/selftrig/st40_top_testbench.txt
      - ip_repo/daphne_ip/sim/selftrig/stc3_testbench.txt
    file_type: user
  formal:
    files:
      - ../../formal/sby/thresholds_axi_lite.sby
    file_type: user

targets:
  default: &default_target
    filesets:
      - rtl_vhdl
      - rtl_verilog
  sim:
    description: GHDL smoke test for the threshold AXI-Lite register path
    filesets:
      - rtl_thresholds
    default_tool: ghdl
    filesets_append:
      - tb_axi_smoke
    toplevel: thresholds_axi_smoke_tb
    tools:
      ghdl:
        analyze_options:
          - --std=08
        run_options:
          - --assert-level=error
          - --stop-time=2us
  sim_legacy:
    <<: *default_target
    description: Legacy self-trigger benches; choose the desired top-level explicitly
    default_tool: xsim
    filesets_append:
      - tb_legacy_vhdl
      - tb_legacy_data
    toplevel: stc3_testbench
  formal:
    filesets:
      - rtl_thresholds
    description: Formal proof of the threshold AXI-Lite register bank reset, decode, and readback behavior
    filesets_append:
      - formal
