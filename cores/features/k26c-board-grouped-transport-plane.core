CAPI=2:

name: dune-daq:daphne:k26c-board-grouped-transport-plane:0.1.0
description: Board-local grouped-source readout egress plane composed from grouped Hermes transport and grouped outbuffer sinks
provider:
  name: local

filesets:
  rtl:
    depend:
      - dune-daq:daphne:grouped-transport-types:0.1.0
      - dune-daq:daphne:k26c-grouped-hermes-transport-plane:0.1.0
      - dune-daq:daphne:k26c-board-grouped-outbuffer-plane:0.1.0
    files:
      - rtl/isolated/subsystems/readout/k26c_board_grouped_transport_plane.vhd
    file_type: vhdlSource-2008

targets:
  default:
    toplevel: k26c_board_grouped_transport_plane
    filesets:
      - rtl
