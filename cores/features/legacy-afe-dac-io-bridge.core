CAPI=2:

name: dune-daq:daphne:legacy-afe-dac-io-bridge:0.1.0
description: Legacy analog compatibility bridge wrapping the live AFE SPI and DAC SPI endpoints
provider:
  name: local

filesets:
  rtl:
    depend:
      - dune-daq:daphne:afe-interface:0.1.0
      - dune-daq:daphne:dac-interface:0.1.0
    files:
      - rtl/isolated/subsystems/analog/legacy_afe_dac_io_bridge.vhd
    file_type: vhdlSource

targets:
  default:
    filesets:
      - rtl
