[Unit]
Description=Hermes IPBus UDP server (DAPHNE mode)
After=endpoint.service firmware.service
Requires=endpoint.service firmware.service
PartOf=firmware.service

[Service]
Type=simple
WorkingDirectory=/
ExecStartPre=/bin/echo Starting Hermes IPBus UDP server \(daphne mode\)
ExecStart=/bin/sh -c '/usr/bin/hermes_udp_srv -d daphne -c true \
  2>/var/log/hermes_udp_srv.err >/var/log/hermes_udp_srv.log'
Restart=on-failure
RestartSec=1
TimeoutStopSec=5s

[Install]
WantedBy=multi-user.target
