[options]
mode cover
depth 2

[engines]
smtbmc z3

[script]
# Cover a live public composable-top timing scenario with a ready endpoint
# image, a repeated timestamp pattern, and a matching sync byte propagated to
# the public seam.
plugin -i ghdl
ghdl --std=08 daphne_package.vhd daphne_subsystem_pkg.vhd frontend_island_validate_stub.vhd afe_capture_to_trigger_bank.vhd frontend_to_selftrigger_adapter.vhd spim_afe1.vhd spim_dac2.vhd afe_config_slice.vhd afe_config_slice_boundary.vhd afe_analog_island.vhd afe_selftrigger_island_validate_stub.vhd afe_subsystem_island.vhd afe_subsystem_fabric.vhd timing_subsystem_boundary.vhd hermes_boundary.vhd daphne_composable_core_top.vhd daphne_composable_frontend_shell.vhd daphne_composable_top.vhd daphne_composable_top_formal.vhd daphne_composable_top_timing_cover.psl -e daphne_composable_top_formal
prep -top daphne_composable_top_formal

