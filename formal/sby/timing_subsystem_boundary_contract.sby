[options]
mode prove
depth 2

[engines]
smtbmc z3

[script]
# Boundary-level proof: the isolated timing wrapper stays neutral in local mode
# and exposes a deterministic endpoint-selected status/timestamp/sync contract.
plugin -i ghdl
ghdl --std=08 daphne_subsystem_pkg.vhd timing_subsystem_boundary.vhd timing_subsystem_boundary_formal.vhd -e timing_subsystem_boundary_formal
prep -top timing_subsystem_boundary_formal

[files]
../../rtl/isolated/common/daphne_subsystem_pkg.vhd
../../rtl/isolated/subsystems/timing/timing_subsystem_boundary.vhd
../vhdl/timing_subsystem_boundary_formal.vhd
